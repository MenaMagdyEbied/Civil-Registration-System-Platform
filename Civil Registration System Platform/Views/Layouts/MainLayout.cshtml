<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body class="d-flex flex-column min-vh-100 mb-0">
    <div>
        @RenderSection("TopNav", required: false)
    </div>
    <div>
        <div class="nav-bar">
            <nav class="gov-navbar navbar navbar-expand-lg">
                <div class="container">

                    @* Brand *@
                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                        <span class="brand-icon">🏛️</span>
                        <div>
                            <div>نظام التسجيل المدني</div>
                            <div style="font-size:0.7rem;font-weight:400;opacity:0.7;">جمهورية مصر العربية</div>
                        </div>
                    </a>

                    @* Mobile Toggler *@
                    <button class="navbar-toggler" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#mainNav"
                            aria-controls="mainNav"
                            aria-expanded="false"
                            aria-label="تبديل القائمة">
                        <i class="bi bi-list" style="color:#fff;font-size:1.5rem;"></i>
                        <i class="bi bi-x-lg" style="color:#fff;font-size:1.2rem;display:none;"></i>
                    </button>

                    @* Nav Collapse *@
                    <div class="collapse d-flex justify-content-between navbar-collapse" id="mainNav">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                            <li class="nav-item">
                                <a class="nav-link active" asp-controller="Home" asp-action="Index">
                                    الرئيسية
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="services">
                                    الخدمات
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="fees">
                                    الرسوم
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="how-it-works">
                                    كيف تعمل
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Track" asp-action="Index">
                                    تتبع طلب
                                </a>
                            </li>

                        </ul>
                        <div class="d-flex gap-2 nav-buttons">
                            <a class="btn btn-gov-outline btn-sm" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i> تسجيل الدخول
                            </a>
                            <a class="btn btn-gov-gold btn-sm" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus me-1"></i> حساب جديد
                            </a>
                        </div>
                    </div>
                 
                </div>
                
            </nav>
        </div>
       
    </div>

    <div class="flex-grow-1">
        @RenderBody()
    </div>
    <div>
        <footer class="gov-footer ">
            <div class="container">
                <div class="row">

                    @* عن النظام *@
                    <div class="col-lg-3 col-md-6 pb-4">
                        <h5><i class="bi bi-building me-2"></i>عن النظام</h5>
                        <p style="font-size:0.88rem;line-height:1.8;">
                            نظام التسجيل المدني هو منصة إلكترونية موحدة تابعة لوزارة الداخلية المصرية،
                            تهدف إلى رقمنة وتسهيل الوصول لجميع خدمات الأحوال المدنية.
                        </p>
                        <div class="d-flex gap-3 mt-3">
                            <a href="#" style="width:35px;height:35px;border-radius:50%;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.7);transition:all 0.3s;">
                                <i class="bi bi-facebook"></i>
                            </a>
                            <a href="#" style="width:35px;height:35px;border-radius:50%;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.7);transition:all 0.3s;">
                                <i class="bi bi-twitter-x"></i>
                            </a>
                            <a href="#" style="width:35px;height:35px;border-radius:50%;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.7);transition:all 0.3s;">
                                <i class="bi bi-youtube"></i>
                            </a>
                        </div>
                    </div>

                    @* روابط سريعة *@
                    <div class="col-lg-3 col-md-6 pb-4">
                        <h5><i class="bi bi-link-45deg me-2"></i>روابط سريعة</h5>
                        <ul>
                            <li><a asp-controller="Home" asp-action="Index"><i class="bi bi-chevron-left"></i> الرئيسية</a></li>
                            <li><a asp-controller="Home" asp-action="Index" asp-fragment="services"><i class="bi bi-chevron-left"></i> الخدمات</a></li>
                            <li><a asp-controller="Home" asp-action="Index" asp-fragment="fees"><i class="bi bi-chevron-left"></i> جدول الرسوم</a></li>
                            <li><a asp-controller="Home" asp-action="Index" asp-fragment="how-it-works"><i class="bi bi-chevron-left"></i> كيف تعمل المنصة</a></li>
                            <li><a asp-controller="Track" asp-action="Index"><i class="bi bi-chevron-left"></i> تتبع طلب</a></li>
                            <li><a asp-controller="Account" asp-action="Login"><i class="bi bi-chevron-left"></i> تسجيل الدخول</a></li>
                        </ul>
                    </div>

                    @* الخدمات *@
                    <div class="col-lg-3 col-md-6 mb-4">
                        <h5><i class="bi bi-grid me-2"></i>الخدمات</h5>
                        <ul>
                            <li><a asp-controller="Apply" asp-action="Index" asp-route-service="birth"><i class="bi bi-chevron-left"></i> شهادة الميلاد</a></li>
                            <li><a asp-controller="Apply" asp-action="Index" asp-route-service="nationalid"><i class="bi bi-chevron-left"></i> بطاقة الرقم القومي</a></li>
                            <li><a asp-controller="Apply" asp-action="Index" asp-route-service="passport"><i class="bi bi-chevron-left"></i> جواز السفر</a></li>
                            <li><a asp-controller="Apply" asp-action="Index" asp-route-service="license"><i class="bi bi-chevron-left"></i> رخصة القيادة</a></li>
                            <li><a asp-controller="Apply" asp-action="Index" asp-route-service="marriage"><i class="bi bi-chevron-left"></i> قسيمة الزواج</a></li>
                            <li><a asp-controller="Apply" asp-action="Index" asp-route-service="death"><i class="bi bi-chevron-left"></i> شهادة الوفاة</a></li>
                        </ul>
                    </div>

                    @* تواصل معنا *@
                    <div class="col-lg-3 col-md-6 pb-4">
                        <h5><i class="bi bi-headset me-2"></i>تواصل معنا</h5>
                        <ul>
                            <li>
                                <a href="tel:15444"><i class="bi bi-telephone me-2"></i> 15444</a>
                            </li>
                            <li>
                                <a href="mailto:support@crs.gov.eg"><i class="bi bi-envelope me-2"></i> support@crs.gov.eg</a>
                            </li>
                            <li>
                                <span style="display:flex;align-items:center;gap:8px;font-size:0.88rem;color:rgba(255,255,255,0.6);">
                                    <i class="bi bi-geo-alt me-1"></i> القاهرة، مصر
                                </span>
                            </li>
                            <li>
                                <span style="display:flex;align-items:center;gap:8px;font-size:0.88rem;color:rgba(255,255,255,0.6);">
                                    <i class="bi bi-clock me-1"></i> الأحد - الخميس: 8 ص - 4 م
                                </span>
                            </li>
                        </ul>
                    </div>

                </div>

                @* Footer Bottom *@
                <div class="footer-bottom">
                    <p class="mb-0">© @DateTime.Now.Year نظام التسجيل المدني - جمهورية مصر العربية. جميع الحقوق محفوظة.</p>
                </div>
            </div>
        </footer>

       
        <button class="scroll-top-btn" aria-label="العودة للأعلى">
            <i class="bi bi-chevron-up"></i>
        </button>
    </div>

   
    <script src="~/lib/bootstrap/dist/js/bootstrap.js"></script>
    <script src="~/js/site.js"></script>
</body>
</html>
