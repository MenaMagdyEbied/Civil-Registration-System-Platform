@model IEnumerable<ApplicationSummaryClientVM>
@{
    ViewData["Title"] = "طلباتي";
}

@await Html.PartialAsync("_DashboardBreadcrumb")

<main class="container py-4">
    <div class="bg-white rounded-3 shadow-sm p-4" style="border:1px solid var(--gov-border);">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <h4 style="font-weight:800;color:var(--gov-primary);margin:0;">
                <i class="bi bi-folder2-open ms-2" style="color:var(--gov-secondary);"></i> جميع طلباتي
            </h4>
            <a asp-controller="Apply" asp-action="SelectService" class="btn btn-gov-gold btn-sm">
                <i class="bi bi-plus-circle ms-1"></i> طلب جديد
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox" style="font-size:4rem;color:var(--gov-text-light);"></i>
                <p style="color:var(--gov-text-light);margin-top:15px;font-size:1.1rem;">لا توجد طلبات بعد</p>
                <a asp-controller="Apply" asp-action="SelectService" class="btn btn-gov-gold mt-3">
                    <i class="bi bi-plus-circle ms-1"></i> تقديم طلب جديد
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="fee-table">
                    <thead>
                        <tr>
                            <th>رقم الطلب</th>
                            <th>الخدمة</th>
                            <th>الحالة</th>
                            <th>المكتب</th>
                            <th>التاريخ</th>
                            <th>إجراء</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td style="font-weight:600;" dir="ltr">@app.ApplicationNumber</td>
                                <td>@app.ServiceTypeName</td>
                                <td>
                                    <span style="color:@app.StatusColor;font-weight:700;">
                                        <span style="width:8px;height:8px;border-radius:50%;background:@app.StatusColor;display:inline-block;margin-left:5px;"></span>
                                        @app.StatusName
                                    </span>
                                </td>
                                <td>@app.OfficeName</td>
                                <td>@app.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <a asp-controller="Dashboard" asp-action="Details" asp-route-id="@app.ApplicationId" class="btn btn-gov-primary btn-sm" style="padding:4px 14px;font-size:0.8rem;border-radius:8px;">
                                        تفاصيل
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</main>
