@model DashboardVM
@{
    ViewData["Title"] = "لوحة التحكم";
}

<main class="container py-4">
    <!-- Welcome Banner -->
    <div class="dashboard-welcome">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 style="font-weight:800;margin-bottom:10px;">مرحباً، <span>@Model.UserName</span></h4>
                <p style="color:rgba(255,255,255,0.75);margin-bottom:20px;font-size:1rem;">
                    تابع طلباتك وقدم على خدمات جديدة. المواعيد يتم تحديدها بواسطة الموظفين المختصين.
                </p>
                <a asp-controller="Apply" asp-action="SelectService" class="btn btn-gov-gold">
                    <i class="bi bi-plus-circle ms-1"></i> تقديم طلب جديد
                </a>
            </div>
            <div class="col-md-4 d-none d-md-flex justify-content-end">
                <div style="width:120px;height:120px;border-radius:50%;background:rgba(200,164,21,0.15);display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-person-circle" style="font-size:3.5rem;color:var(--gov-secondary);"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="stat-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#e3f2fd;color:#1565c0;"><i class="bi bi-file-earmark-text"></i></div>
                    <div>
                        <div style="font-size:1.5rem;font-weight:800;color:#0d2137;">@Model.PendingApplications</div>
                        <div style="font-size:0.82rem;color:#6c757d;font-weight:600;">طلبات نشطة</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#e8f5e9;color:#1a7a3a;"><i class="bi bi-check-circle"></i></div>
                    <div>
                        <div style="font-size:1.5rem;font-weight:800;color:#0d2137;">@Model.ApprovedApplications</div>
                        <div style="font-size:0.82rem;color:#6c757d;font-weight:600;">تم الإصدار</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#f3e5f5;color:#7b1fa2;"><i class="bi bi-calendar-event"></i></div>
                    <div>
                        <div style="font-size:1.5rem;font-weight:800;color:#0d2137;">@Model.UpcomingAppointments.Count</div>
                        <div style="font-size:0.82rem;color:#6c757d;font-weight:600;">مواعيد قادمة</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#ffebee;color:#c41e3a;"><i class="bi bi-x-circle"></i></div>
                    <div>
                        <div style="font-size:1.5rem;font-weight:800;color:#0d2137;">@Model.RejectedApplications</div>
                        <div style="font-size:0.82rem;color:#6c757d;font-weight:600;">مرفوضة</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- My Applications -->
    <div class="bg-white rounded-3 shadow-sm p-4 mb-4" style="border:1px solid var(--gov-border);">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <h5 style="font-weight:700;color:var(--gov-primary);margin:0;">
                <i class="bi bi-folder2-open ms-2" style="color:var(--gov-secondary);"></i> طلباتي الأخيرة
            </h5>
            <div class="d-flex gap-2">
                <a asp-controller="Dashboard" asp-action="MyApplications" class="btn btn-gov-outline btn-sm">
                    <i class="bi bi-list-ul ms-1"></i> كل الطلبات
                </a>
                <a asp-controller="Apply" asp-action="SelectService" class="btn btn-gov-gold btn-sm">
                    <i class="bi bi-plus-circle ms-1"></i> طلب جديد
                </a>
            </div>
        </div>

        @if (!Model.RecentApplications.Any())
        {
            <div class="text-center py-4">
                <i class="bi bi-inbox" style="font-size:3rem;color:var(--gov-text-light);"></i>
                <p style="color:var(--gov-text-light);margin-top:10px;">لا توجد طلبات بعد</p>
                <a asp-controller="Apply" asp-action="SelectService" class="btn btn-gov-gold mt-2">
                    <i class="bi bi-plus-circle ms-1"></i> تقديم طلب جديد
                </a>
            </div>
        }
        else
        {
            @foreach (var app in Model.RecentApplications)
            {
                <a asp-controller="Dashboard" asp-action="Details" asp-route-id="@app.ApplicationId" class="text-decoration-none">
                    <div class="app-item">
                        <div class="row align-items-center">
                            <div class="col-md-4 mb-2 mb-md-0">
                                <div class="fw-bold" style="color:#0d2137;">@app.ServiceTypeName</div>
                                <div style="font-size:0.78rem;color:#6c757d;" dir="ltr">@app.ApplicationNumber</div>
                            </div>
                            <div class="col-md-3 mb-2 mb-md-0">
                                <span style="width:10px;height:10px;border-radius:50%;background:@app.StatusColor;display:inline-block;"></span>
                                <span style="font-size:0.88rem;font-weight:600;color:@app.StatusColor;">@app.StatusName</span>
                            </div>
                            <div class="col-md-3 mb-2 mb-md-0" style="font-size:0.85rem;color:#6c757d;">
                                <i class="bi bi-building"></i> @app.OfficeName
                            </div>
                            <div class="col-md-2 text-md-start">
                                <div style="font-size:0.82rem;color:#6c757d;">@app.CreatedAt.ToString("yyyy-MM-dd")</div>
                            </div>
                        </div>
                    </div>
                </a>
            }
        }
    </div>

    <!-- Appointments + Notes -->
    <div class="row g-3">
        <div class="col-md-6">
            <div class="bg-white rounded-3 shadow-sm p-4" style="border:1px solid var(--gov-border);height:100%;">
                <h5 style="font-weight:700;color:var(--gov-primary);margin-bottom:20px;">
                    <i class="bi bi-calendar-event ms-2" style="color:var(--gov-secondary);"></i> المواعيد القادمة
                </h5>

                @if (!Model.UpcomingAppointments.Any())
                {
                    <div class="text-center py-3">
                        <i class="bi bi-calendar-x" style="font-size:2rem;color:var(--gov-text-light);"></i>
                        <p style="color:var(--gov-text-light);font-size:0.9rem;margin-top:8px;">لا توجد مواعيد قادمة</p>
                    </div>
                }
                else
                {
                    @foreach (var apt in Model.UpcomingAppointments)
                    {
                        <div class="d-flex gap-3 mb-3 p-3" style="background:#f0f4f8;border-radius:12px;">
                            <div class="text-center" style="min-width:60px;">
                                <div style="background:var(--gov-primary);color:var(--gov-secondary);border-radius:10px;padding:8px 12px;">
                                    <div style="font-size:1.2rem;font-weight:800;">@apt.AppointmentDate.Day</div>
                                    <div style="font-size:0.7rem;font-weight:600;">@apt.AppointmentDate.ToString("MM")</div>
                                </div>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-bold" style="color:var(--gov-primary);font-size:0.95rem;">@apt.ServiceTypeName</div>
                                <div style="font-size:0.82rem;color:var(--gov-text-light);">
                                    رقم الطلب: <span dir="ltr">@apt.ApplicationNumber</span>
                                </div>
                                <div style="font-size:0.82rem;color:var(--gov-text-light);">
                                    الساعة @apt.AppointmentDate.ToString("HH:mm") — @apt.OfficeName
                                </div>
                            </div>
                        </div>
                    }
                }

                <div class="alert alert-gov-info mt-3 mb-0" style="font-size:0.82rem;">
                    <i class="bi bi-info-circle ms-1"></i> المواعيد يتم تحديدها بواسطة الموظف بعد مراجعة طلبك
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="bg-white rounded-3 shadow-sm p-4" style="border:1px solid var(--gov-border);height:100%;">
                <h5 style="font-weight:700;color:var(--gov-primary);margin-bottom:20px;">
                    <i class="bi bi-megaphone ms-2" style="color:var(--gov-secondary);"></i> ملاحظات هامة
                </h5>
                <div class="d-flex gap-3 mb-3 pb-3" style="border-bottom:1px solid var(--gov-border);">
                    <div style="width:40px;height:40px;border-radius:10px;background:#fff3e0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="bi bi-car-front" style="color:#7b1fa2;"></i>
                    </div>
                    <div>
                        <div class="fw-bold" style="color:var(--gov-primary);font-size:0.9rem;">رخصة القيادة</div>
                        <div style="font-size:0.82rem;color:var(--gov-text-light);">
                            بعد مراجعة المستندات، سيحدد الموظف موعد الكشف الطبي ثم النظري ثم العملي.
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-3 mb-3 pb-3" style="border-bottom:1px solid var(--gov-border);">
                    <div style="width:40px;height:40px;border-radius:10px;background:#fff3e0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="bi bi-file-earmark-plus" style="color:#e65100;"></i>
                    </div>
                    <div>
                        <div class="fw-bold" style="color:var(--gov-primary);font-size:0.9rem;">طلب مستندات إضافية</div>
                        <div style="font-size:0.82rem;color:var(--gov-text-light);">
                            في حال طلب الأدمن مستندات إضافية، يمكنك رفعها من صفحة تفاصيل الطلب.
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-3">
                    <div style="width:40px;height:40px;border-radius:10px;background:#e8f5e9;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="bi bi-file-earmark-medical" style="color:#2e7d32;"></i>
                    </div>
                    <div>
                        <div class="fw-bold" style="color:var(--gov-primary);font-size:0.9rem;">الشهادات والقيود</div>
                        <div style="font-size:0.82rem;color:var(--gov-text-light);">
                            يتم إصدارها بعد مراجعة الطلب مباشرة — لا تتطلب مواعيد.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
