@model IEnumerable<AdminListItemVM>
@{
    ViewData["Title"] = "إدارة الأدمن";
}

@await Html.PartialAsync("_DashboardBreadcrumb")

<main class="container py-4">
    <div class="bg-white rounded-3 shadow-sm p-4" style="border:1px solid var(--gov-border);">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <h4 style="font-weight:800;color:var(--gov-primary);margin:0;">
                <i class="bi bi-shield-check ms-2" style="color:var(--gov-secondary);"></i> الأدمن في النظام
            </h4>
            <a asp-action="CreateAdmin" class="btn btn-gov-gold btn-sm">
                <i class="bi bi-person-plus ms-1"></i> إضافة أدمن جديد
            </a>
        </div>

        @if (!Model.Any())
        {
            <p class="text-center text-muted py-5">لا يوجد أدمن مسجلين بعد</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="fee-table">
                    <thead>
                        <tr><th>الاسم</th><th>البريد</th><th>الموبايل</th><th>المكتب المُدار</th><th>المحافظة</th><th>الحالة</th><th>إجراء</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td style="font-weight:600;">
                                    <a asp-action="AdminDetails" asp-route-id="@a.AdminId" style="color:var(--gov-primary);text-decoration:none;">
                                        @a.FullName
                                    </a>
                                </td>
                                <td dir="ltr">@a.Email</td>
                                <td dir="ltr">@a.EGPhoneNumber</td>
                                <td>@a.ManageOfficeName</td>
                                <td>@a.GovernorateName</td>
                                <td>
                                    @if (a.IsActive)
                                    { <span class="badge-gov-success">نشط</span> }
                                    else
                                    { <span class="badge-gov-danger">معطل</span> }
                                </td>
                                <td class="d-flex gap-2">
                                    <a asp-action="AdminDetails" asp-route-id="@a.AdminId" class="btn btn-gov-outline btn-sm" style="padding:4px 10px;font-size:0.78rem;">تفاصيل</a>
                                    <form asp-action="ToggleAdmin" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="adminId" value="@a.AdminId">
                                        <button type="submit" class="btn btn-gov-outline btn-sm" style="padding:4px 10px;font-size:0.78rem;">
                                            @(a.IsActive ? "تعطيل" : "تفعيل")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</main>
