@model ErrorViewModel
@{
    ViewData["Title"] = "خطأ";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <div class="bg-white rounded-3 shadow-sm p-5" style="border:1px solid var(--gov-border);">
                    <div style="width:100px;height:100px;border-radius:50%;background:#ffebee;color:#c41e3a;display:inline-flex;align-items:center;justify-content:center;font-size:3rem;margin-bottom:20px;">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <h3 style="font-weight:800;color:var(--gov-primary);">حدث خطأ غير متوقع</h3>
                    <p style="color:var(--gov-text-light);">نعتذر — حدث خطأ أثناء معالجة طلبك. حاول مرة أخرى أو تواصل مع الدعم.</p>

                    @if (Model?.ShowRequestId == true)
                    {
                        <p class="mt-3" style="font-size:0.85rem;color:var(--gov-text-light);">
                            <strong>رقم الطلب:</strong> <code dir="ltr">@Model.RequestId</code>
                        </p>
                    }

                    <div class="d-flex gap-2 justify-content-center mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-gov-gold">
                            <i class="bi bi-house ms-1"></i> العودة للرئيسية
                        </a>
                        <a href="javascript:history.back()" class="btn btn-gov-outline">
                            <i class="bi bi-arrow-right ms-1"></i> العودة للصفحة السابقة
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
