@model ApplicationTrackResultVM

<div class="text-center mb-4">
    <i class="bi bi-folder2-open" style="font-size:3rem;color:var(--gov-secondary);"></i>
    <h5 class="mt-3" style="font-weight:700;color:var(--gov-white);">@Model.ServiceTypeName</h5>
</div>

<div class="row mb-4" style="color:rgba(255,255,255,0.85);">
    <div class="col-md-6 mb-2"><strong>رقم الطلب:</strong> @Model.ApplicationNumber</div>
    <div class="col-md-6 mb-2"><strong>نوع الطلب:</strong> @Model.ApplicationTypeName</div>
    <div class="col-md-6 mb-2"><strong>تاريخ التقديم:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd")</div>
    <div class="col-md-6 mb-2">
        <strong>الحالة:</strong>
        <span style="color:@Model.StatusColor;font-weight:700;">@Model.StatusName</span>
    </div>
    <div class="col-md-6 mb-2"><strong>المكتب:</strong> @Model.OfficeName</div>
    <div class="col-md-6 mb-2"><strong>الرسوم:</strong> <span style="color:var(--gov-secondary);font-weight:700;">@Model.Price ج.م</span></div>
</div>

<h6 style="font-weight:700;margin-bottom:15px;color:var(--gov-white);">مراحل الطلب</h6>
<div class="track-timeline">
    @if (Model.Timeline != null && Model.Timeline.Any())
    {
        foreach (var t in Model.Timeline)
        {
            <div class="timeline-item completed">
                <h6>@t.StatusName</h6>
                <p>@t.Timestamp.ToString("yyyy-MM-dd HH:mm")</p>
                @if (!string.IsNullOrEmpty(t.Description))
                {
                    <p style="font-size:0.78rem;color:rgba(255,255,255,0.5);">@t.Description</p>
                }
                @if (!string.IsNullOrEmpty(t.PerformedByName))
                {
                    <p style="font-size:0.7rem;color:rgba(255,255,255,0.45);">بواسطة: @t.PerformedByName</p>
                }
            </div>
        }
    }
</div>
