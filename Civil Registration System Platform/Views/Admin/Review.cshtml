@model ReviewApplicationVM
@{
    ViewData["Title"] = "مراجعة طلب";
}

@await Html.PartialAsync("_DashboardBreadcrumb")

<main class="container py-4">

    <!-- Application Info -->
    <div class="bg-white rounded-3 shadow-sm p-4 mb-3" style="border:1px solid var(--gov-border);">
        <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
            <div>
                <h4 style="font-weight:800;color:var(--gov-primary);margin:0;">@Model.ServiceTypeName</h4>
                <div style="font-size:0.9rem;color:var(--gov-text-light);">
                    رقم: <span dir="ltr" style="color:var(--gov-secondary);font-weight:700;">@Model.ApplicationNumber</span>
                </div>
            </div>
            <span class="badge-gov-info" style="font-size:0.95rem;">@Model.StatusName</span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-2"><strong>الاسم:</strong> @Model.ApplicantName</div>
            <div class="col-md-6 mb-2"><strong>الرقم القومي:</strong> <span dir="ltr">@Model.ApplicantNationalId</span></div>
            <div class="col-md-6 mb-2"><strong>الموبايل:</strong> <span dir="ltr">@Model.ApplicantPhone</span></div>
            <div class="col-md-6 mb-2"><strong>المحافظة:</strong> @Model.ApplicantGovernorateName</div>
            <div class="col-md-6 mb-2"><strong>المكتب:</strong> @Model.OfficeName</div>
            <div class="col-md-6 mb-2"><strong>نوع الطلب:</strong> @Model.ApplicationTypeName</div>
            <div class="col-md-6 mb-2"><strong>الرسوم:</strong> <span style="color:var(--gov-secondary);font-weight:700;">@Model.Price ج.م</span></div>
            <div class="col-md-6 mb-2"><strong>تاريخ التقديم:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd")</div>
        </div>

        @if (!string.IsNullOrEmpty(Model.RejectionReason))
        {
            <div class="alert alert-gov-danger mt-3">
                <strong>سبب الرفض:</strong> @Model.RejectionReason
            </div>
        }
    </div>

    <!-- Documents -->
    <div class="bg-white rounded-3 shadow-sm p-4 mb-3" style="border:1px solid var(--gov-border);">
        <h5 style="font-weight:700;color:var(--gov-primary);margin-bottom:15px;">
            <i class="bi bi-file-earmark ms-2" style="color:var(--gov-secondary);"></i> المستندات المرفوعة
        </h5>

        @if (Model.Documents != null && Model.Documents.Any())
        {
            <div class="row g-3">
                @foreach (var doc in Model.Documents)
                {
                    <div class="col-md-6 col-lg-4">
                        <div style="border:1px solid var(--gov-border);border-radius:10px;padding:12px;">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-file-earmark-text" style="font-size:1.5rem;color:var(--gov-secondary);"></i>
                                <strong style="font-size:0.9rem;">@doc.Name</strong>
                            </div>
                            <div style="font-size:0.78rem;color:var(--gov-text-light);">
                                رفع: @doc.UploadedAt.ToString("yyyy-MM-dd HH:mm")
                            </div>
                            <a href="/@doc.DocumentPath" target="_blank" class="btn btn-gov-outline btn-sm mt-2 w-100">
                                <i class="bi bi-eye ms-1"></i> عرض
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">لا توجد مستندات مرفوعة.</p>
        }
    </div>

    <!-- Actions -->
    @{
        var isFinal = Model.StatusName == ApplicationStatus.Issued.ToArabicName()
                   || Model.StatusName == ApplicationStatus.Rejected.ToArabicName()
                   || Model.StatusName == ApplicationStatus.Cancelled.ToArabicName();
    }

    @if (!isFinal && User.IsInRole("Employee"))
    {
        <div class="bg-white rounded-3 shadow-sm p-4 mb-3" style="border:1px solid var(--gov-border);">
            <h5 style="font-weight:700;color:var(--gov-primary);margin-bottom:15px;">
                <i class="bi bi-tools ms-2" style="color:var(--gov-secondary);"></i> إجراءات
            </h5>

            <div class="row g-3">
                <!-- Approve -->
                <div class="col-md-6">
                    <form asp-action="Approve" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="applicationId" value="@Model.ApplicationId">
                        <textarea name="notes" class="form-control mb-2" rows="2" placeholder="ملاحظات (اختيارية)"></textarea>
                        <button type="submit" class="btn btn-gov-success w-100">
                            <i class="bi bi-check-circle ms-1"></i> قبول الطلب
                        </button>
                    </form>
                </div>

                <!-- Reject -->
                <div class="col-md-6">
                    <form asp-action="Reject" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="applicationId" value="@Model.ApplicationId">
                        <textarea name="reason" class="form-control mb-2" rows="2" placeholder="سبب الرفض (مطلوب)" required></textarea>
                        <button type="submit" class="btn btn-gov-danger w-100">
                            <i class="bi bi-x-circle ms-1"></i> رفض الطلب
                        </button>
                    </form>
                </div>

                <!-- Request Info -->
                <div class="col-md-6">
                    <form asp-action="RequestInfo" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="applicationId" value="@Model.ApplicationId">
                        <textarea name="details" class="form-control mb-2" rows="2" placeholder="ما المستندات الإضافية المطلوبة؟" required></textarea>
                        <button type="submit" class="btn btn-gov-warning w-100">
                            <i class="bi bi-file-earmark-plus ms-1"></i> طلب مستندات إضافية
                        </button>
                    </form>
                </div>

                <!-- Issue -->
                <div class="col-md-6">
                    <form asp-action="Issue" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="applicationId" value="@Model.ApplicationId">
                        <button type="submit" class="btn btn-gov-primary w-100" style="height:100%;">
                            <i class="bi bi-stamp ms-1"></i> إصدار الوثيقة
                        </button>
                    </form>
                </div>
            </div>

            <!-- Schedule Appointment (مفيد بشكل خاص للرخصة) -->
            <hr class="my-4">
            <h6 style="font-weight:700;color:var(--gov-primary);margin-bottom:10px;">
                <i class="bi bi-calendar-plus ms-2" style="color:var(--gov-secondary);"></i> جدولة موعد
            </h6>

            <form asp-action="ScheduleAppointment" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ApplicationId" value="@Model.ApplicationId">

                <div class="col-md-3">
                    <label class="form-label small">التاريخ</label>
                    <input type="date" name="AppointmentDate" class="form-control" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">الوقت</label>
                    <input type="time" name="AppointmentTime" class="form-control" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">المرحلة (للرخصة)</label>
                    <select name="TargetStatus" class="form-select">
                        <option value="">عام</option>
                        <option value="@ApplicationStatus.MedicalExamPending">كشف طبي</option>
                        <option value="@ApplicationStatus.TheoryTestPending">اختبار نظري</option>
                        <option value="@ApplicationStatus.PracticalTestPending">اختبار عملي</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-gov-gold w-100">
                        <i class="bi bi-calendar-check ms-1"></i> جدولة
                    </button>
                </div>
            </form>

            @if (Model.AppointmentDate.HasValue)
            {
                <div class="alert alert-gov-info mt-3">
                    <i class="bi bi-calendar-event ms-2"></i>
                    موعد محدد:
                    <strong>@Model.AppointmentDate.Value.ToString("yyyy-MM-dd")</strong>
                    @if (Model.AppointmentTime.HasValue)
                    { <text> الساعة <strong>@Model.AppointmentTime.Value.ToString(@"hh\:mm")</strong></text> }
                </div>
            }
        </div>
    }
    else if (!isFinal && User.IsInRole("Admin"))
    {
        <div class="alert alert-gov-info shadow-sm">
            <i class="bi bi-info-circle ms-2"></i>
            أنت تشاهد هذا الطلب بصفة <strong>أدمن</strong>. الإجراءات (القبول والرفض) متاحة فقط لحسابات الموظفين.
        </div>
    }

    <!-- Timeline -->
    <div class="bg-white rounded-3 shadow-sm p-4" style="border:1px solid var(--gov-border);">
        <h5 style="font-weight:700;color:var(--gov-primary);margin-bottom:15px;">
            <i class="bi bi-clock-history ms-2" style="color:var(--gov-secondary);"></i> سجل الطلب
        </h5>

        @if (Model.Timeline != null && Model.Timeline.Any())
        {
            <div style="position:relative;padding-right:30px;border-right:2px solid var(--gov-border);">
                @foreach (var t in Model.Timeline)
                {
                    <div class="mb-3 pb-3" style="border-bottom:1px dashed var(--gov-border);position:relative;">
                        <div style="position:absolute;right:-39px;top:0;width:14px;height:14px;background:var(--gov-secondary);border-radius:50%;border:3px solid #fff;box-shadow:0 0 0 1px var(--gov-border);"></div>
                        <div class="d-flex justify-content-between flex-wrap">
                            <strong style="color:var(--gov-primary);">@t.StatusName</strong>
                            <small style="color:var(--gov-text-light);">@t.Timestamp.ToString("yyyy-MM-dd HH:mm")</small>
                        </div>
                        @if (!string.IsNullOrEmpty(t.Description))
                        { <div style="font-size:0.9rem;">@t.Description</div> }
                        @if (!string.IsNullOrEmpty(t.PerformedByName))
                        { <div style="font-size:0.78rem;color:var(--gov-text-light);">بواسطة: @t.PerformedByName</div> }
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">لا توجد إدخالات.</p>
        }
    </div>
</main>
