@model IEnumerable<GetAllUserUnConfirmed>
@{
    ViewData["Title"] = "اعتماد المواطنين";
}

@await Html.PartialAsync("_DashboardBreadcrumb")

<main class="container py-4">
    <div class="bg-white rounded-3 shadow-sm p-4" style="border:1px solid var(--gov-border);">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <h4 style="font-weight:800;color:var(--gov-primary);margin:0;">
                <i class="bi bi-person-check ms-2" style="color:var(--gov-secondary);"></i> المواطنين بانتظار الاعتماد
            </h4>
            <a asp-action="OfficeUsers" class="btn btn-gov-outline btn-sm">
                <i class="bi bi-people ms-1"></i> كل المواطنين
            </a>
        </div>

        <div class="alert alert-gov-info">
            <i class="bi bi-info-circle ms-2"></i>
            راجع البيانات وقارنها مع صورة البطاقة. اعتمد الحساب لو البيانات صحيحة، أو ارفضه مع توضيح السبب.
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-check2-all" style="font-size:3rem;color:var(--gov-green);"></i>
                <p style="color:var(--gov-text-light);margin-top:10px;">لا يوجد مواطنين بانتظار الاعتماد</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var u in Model)
                {
                    <div class="col-md-6">
                        <div class="bg-white rounded-3 p-3" style="border:1px solid var(--gov-border);">
                            <div class="row">
                                <div class="col-md-5 text-center">
                                    @if (!string.IsNullOrEmpty(u.CardImagePath))
                                    {
                                        <a href="@u.CardImagePath" target="_blank">
                                            <img src="@u.CardImagePath" alt="بطاقة" class="img-fluid rounded" style="max-height:140px;border:1px solid var(--gov-border);">
                                        </a>
                                    }
                                    else
                                    {
                                        <div style="width:100px;height:100px;background:var(--gov-light);border-radius:10px;display:inline-flex;align-items:center;justify-content:center;">
                                            <i class="bi bi-person" style="font-size:3rem;color:var(--gov-text-light);"></i>
                                        </div>
                                    }
                                </div>
                                <div class="col-md-7" style="font-size:0.85rem;">
                                    <div><strong>الاسم:</strong> @u.FullName</div>
                                    <div><strong>الرقم القومي:</strong> <span dir="ltr">@u.NationalID</span></div>
                                    <div><strong>البريد:</strong> <span dir="ltr">@u.Email</span></div>
                                    <div><strong>الموبايل:</strong> <span dir="ltr">@u.EGPhoneNumber</span></div>
                                    <div><strong>المحافظة:</strong> @u.GovernorateName</div>
                                    <div><strong>المكتب:</strong> @u.OfficeName</div>
                                    <div><strong>التسجيل:</strong> @u.CreatedAt.ToString("yyyy-MM-dd")</div>
                                </div>
                            </div>

                            <hr class="my-3">

                            <div class="d-flex gap-2 flex-wrap">
                                <form asp-action="ConfirmUser" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@u.UserId">
                                    <button type="submit" class="btn btn-gov-success btn-sm">
                                        <i class="bi bi-check-circle ms-1"></i> اعتماد
                                    </button>
                                </form>

                                <button class="btn btn-gov-danger btn-sm" data-bs-toggle="collapse" data-bs-target="#reject-@u.UserId">
                                    <i class="bi bi-x-circle ms-1"></i> رفض
                                </button>
                            </div>

                            <div class="collapse mt-2" id="reject-@u.UserId">
                                <form asp-action="RejectUser" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@u.UserId">
                                    <textarea name="messageReject" class="form-control mb-2" rows="2" placeholder="سبب الرفض" required></textarea>
                                    <button type="submit" class="btn btn-gov-danger btn-sm">تأكيد الرفض</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</main>
