@{
    ViewData["Title"] = "تم تقديم الطلب بنجاح";
    var appNumber = ViewBag.ApplicationNumber as string;
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <div class="bg-white rounded-3 shadow-sm p-5" style="border:1px solid var(--gov-border);">
                    <div style="width:100px;height:100px;border-radius:50%;background:#e8f5e9;color:#1a7a3a;display:inline-flex;align-items:center;justify-content:center;font-size:3rem;margin-bottom:20px;">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <h3 style="font-weight:800;color:var(--gov-primary);margin-bottom:10px;">تم تقديم الطلب بنجاح</h3>
                    <p style="color:var(--gov-text-light);font-size:1.05rem;margin-bottom:20px;">
                        رقم الطلب:
                        <strong style="color:var(--gov-secondary);font-size:1.4rem;letter-spacing:2px;" dir="ltr">@appNumber</strong>
                    </p>

                    <div class="alert alert-gov-info mb-4" style="max-width:600px;margin:15px auto;">
                        <i class="bi bi-info-circle ms-2"></i>
                        احتفظ برقم الطلب لاستخدامه في تتبع حالة المعاملة. سيتم مراجعة طلبك من قبل الموظف المختص.
                    </div>

                    <div class="d-flex gap-3 justify-content-center flex-wrap">
                        <a asp-controller="Home" asp-action="Track" asp-route-id="@appNumber" class="btn btn-gov-gold">
                            <i class="bi bi-search ms-2"></i> تتبع الطلب
                        </a>
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-gov-primary">
                            <i class="bi bi-speedometer2 ms-2"></i> لوحة التحكم
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
