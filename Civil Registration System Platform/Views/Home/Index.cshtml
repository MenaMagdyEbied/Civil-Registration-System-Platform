@* ===== HOW IT WORKS SECTION ===== *@
<section class="gov-steps" id="how-it-works">
    <div class="container">
        <div class="section-title fade-up">
            <h2>كيف تقدم طلبك</h2>
            <div class="title-line"></div>
            <p>أربع خطوات بسيطة للحصول على الخدمة المطلوبة</p>
        </div>
        <div class="row">
            <div class="col-md-3 fade-up">
                <div class="step-item">
                    <div class="step-number"><i class="bi bi-hand-index"></i></div>
                    <h5>اختيار الخدمة</h5>
                    <p>اختر الخدمة المطلوبة من قائمة الخدمات المتاحة</p>
                    <div class="step-connector"></div>
                </div>
            </div>
            <div class="col-md-3 fade-up">
                <div class="step-item">
                    <div class="step-number"><i class="bi bi-pencil-square"></i></div>
                    <h5>تعبئة البيانات</h5>
                    <p>أدخل بياناتك الشخصية ومعلومات الطلب المطلوب</p>
                    <div class="step-connector"></div>
                </div>
            </div>
            <div class="col-md-3 fade-up">
                <div class="step-item">
                    <div class="step-number"><i class="bi bi-credit-card"></i></div>
                    <h5>رفع المستندات ودفع الرسوم</h5>
                    <p>ارفع المستندات المطلوبة وقم بسداد الرسوم المقررة</p>
                    <div class="step-connector"></div>
                </div>
            </div>
            <div class="col-md-3 fade-up">
                <div class="step-item">
                    <div class="step-number"><i class="bi bi-check-circle"></i></div>
                    <h5>استلام الخدمة</h5>
                    <p>استلم الخدمة إلكترونياً أو من أقرب مكتب تسجيل مدني</p>
                </div>
            </div>
        </div>
    </div>
</section>

@* ===== TRACK SECTION ===== *@
<section class="track-section" id="track">
    <div class="container">
        <div class="text-center mb-4 fade-up">
            <h2 style="font-weight:800;color:#fff;">تتبع طلبك</h2>
            <p style="color:rgba(255,255,255,0.6);">أدخل رقم الطلب لمعرفة حالة المعاملة</p>
        </div>
        <div class="track-card fade-up">
            <div class="text-center mb-3">
                <i class="bi bi-search" style="font-size:2.5rem;color:var(--gov-secondary);"></i>
            </div>
            <form asp-controller="Home" asp-action="Track" method="post">
    
                <div class="mb-3">
                    <input type="text" name="applicationNumber" id="trackInput"
                           class="form-control"
                           placeholder="أدخل رقم الطلب - مثال: CRS-2025-0042"
                           dir="ltr" style="text-align:center;">
                </div>

