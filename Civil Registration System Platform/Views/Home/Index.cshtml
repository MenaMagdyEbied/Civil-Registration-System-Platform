@model HomePageVM
@{
    ViewData["Title"] = "الرئيسية";
}

<!-- ===== HERO SECTION ===== -->
<section class="gov-hero" id="home">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <div class="hero-badge">🛡️ منصة رسمية تابعة لوزارة الداخلية</div>
                <h1>
                    نظام التسجيل المدني
                    <br>
                    <span>رقمنة الخدمات الحكومية</span>
                </h1>
                <p>
                    منصة إلكترونية موحدة تمكّن المواطنين من التقديم على جميع خدمات الأحوال المدنية
                    والهوية والجوازات ورخص القيادة أونلاين، بسهولة وأمان.
                </p>
                <div class="d-flex gap-3 mt-4 flex-wrap">
                    <a href="#services" class="btn btn-gov-gold">
                        <i class="bi bi-grid me-2"></i> تصفح الخدمات
                    </a>
                    <a asp-controller="Home" asp-action="Track" class="btn btn-gov-outline" style="border-radius:10px;">
                        <i class="bi bi-search me-2"></i> تتبع طلبك
                    </a>
                </div>
                <div class="hero-stats">
                    <div class="hero-stat"><h3>@Model.ServiceCards.Count</h3><p>خدمات</p></div>
                    <div class="hero-stat"><h3>27</h3><p>محافظة</p></div>
                    <div class="hero-stat"><h3>+50,000</h3><p>طلب شهرياً</p></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== QUICK SERVICES BAR ===== -->
<div class="quick-services-bar">
    <div class="container">
        <div class="row text-center g-2">
            @foreach (var svc in Model.ServiceCards)
            {
                <div class="col">
                    <a asp-controller="Apply" asp-action="Index" asp-route-serviceType="@svc.ServiceTypeId" class="quick-service-item">
                        <div class="quick-service-icon @svc.ColorClass">
                            <i class="bi @svc.Icon"></i>
                        </div>
                        <span>@svc.ServiceTypeName</span>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- ===== SERVICES SECTION ===== -->
<section class="py-5" id="services">
    <div class="container">
        <div class="section-title fade-up">
            <h2>خدماتنا</h2>
            <div class="title-line"></div>
            <p>جميع خدمات الأحوال المدنية والهوية والجوازات ورخص القيادة في مكان واحد</p>
        </div>

        <div class="text-center mb-4 fade-up">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-gov-primary btn-sm active" data-filter="all">الكل</button>
                <button type="button" class="btn btn-gov-primary btn-sm" data-filter="civil">أحوال مدنية</button>
                <button type="button" class="btn btn-gov-primary btn-sm" data-filter="identity">الهوية</button>
                <button type="button" class="btn btn-gov-primary btn-sm" data-filter="travel">الجوازات والمرور</button>
            </div>
        </div>

        <div class="row g-4" id="serviceCards">
            @foreach (var svc in Model.ServiceCards)
            {
                <div class="col-md-6 col-lg-4 fade-up" data-category="@svc.Category">
                    <div class="service-card">
                        <div class="card-icon @svc.ColorClass"><i class="bi @svc.Icon"></i></div>
                        <h5>@svc.ServiceTypeName</h5>
                        <p>@svc.Description</p>
                        <div class="card-meta">
                            <span class="price">@svc.PriceRange</span>
                            <span class="time"><i class="bi bi-clock me-1"></i> @svc.DurationText</span>
                        </div>
                        <a asp-controller="Apply" asp-action="Index" asp-route-serviceType="@svc.ServiceTypeId" class="btn btn-gov-primary btn-sm mt-3 w-100">
                            <i class="bi bi-arrow-left me-1"></i> تقديم طلب
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ===== FEES SECTION ===== -->
<section class="py-5 bg-white" id="fees">
    <div class="container">
        <div class="section-title fade-up">
            <h2>جدول الرسوم</h2>
            <div class="title-line"></div>
            <p>تعرّف على الرسوم المقررة لكل خدمة من خدمات التسجيل المدني</p>
        </div>

        <div class="fade-up">
            <div class="table-responsive">
                <table class="fee-table">
                    <thead>
                        <tr>
                            <th>الخدمة</th>
                            <th>نوع الطلب</th>
                            <th>الرسوم</th>
                            <th>المدة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.FeeRows)
                        {
                            <tr>
                                @if (row.IsGroupHeader)
                                {
                                    <td rowspan="@row.RowSpan" style="font-weight:700;">@row.ServiceTypeName</td>
                                }
                                <td>@row.ApplicationTypeName</td>
                                <td>@row.PriceDisplay</td>
                                <td>@row.DurationDisplay</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<!-- ===== HOW IT WORKS ===== -->
<section class="gov-steps" id="how-it-works">
    <div class="container">
        <div class="section-title fade-up">
            <h2>كيف تقدم طلبك</h2>
            <div class="title-line"></div>
            <p>أربع خطوات بسيطة للحصول على الخدمة المطلوبة</p>
        </div>
        <div class="row">
            <div class="col-md-3 fade-up">
                <div class="step-item">
                    <div class="step-number"><i class="bi bi-hand-index"></i></div>
                    <h5>اختيار الخدمة</h5>
                    <p>اختر الخدمة المطلوبة من القائمة</p>
                    <div class="step-connector"></div>
                </div>
            </div>
            <div class="col-md-3 fade-up">
                <div class="step-item">
                    <div class="step-number"><i class="bi bi-pencil-square"></i></div>
                    <h5>تعبئة البيانات</h5>
                    <p>أدخل بياناتك الشخصية ومعلومات الطلب</p>
                    <div class="step-connector"></div>
                </div>
            </div>
            <div class="col-md-3 fade-up">
                <div class="step-item">
                    <div class="step-number"><i class="bi bi-credit-card"></i></div>
                    <h5>رفع المستندات ودفع الرسوم</h5>
                    <p>ارفع المستندات وسدد الرسوم</p>
                    <div class="step-connector"></div>
                </div>
            </div>
            <div class="col-md-3 fade-up">
                <div class="step-item">
                    <div class="step-number"><i class="bi bi-check-circle"></i></div>
                    <h5>استلام الخدمة</h5>
                    <p>استلم الوثيقة إلكترونياً أو من المكتب</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('[data-filter]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var filter = this.getAttribute('data-filter');
                document.querySelectorAll('[data-filter]').forEach(function (b) { b.classList.remove('active'); });
                this.classList.add('active');
                document.querySelectorAll('#serviceCards > [data-category]').forEach(function (card) {
                    card.style.display = (filter === 'all' || card.getAttribute('data-category') === filter) ? '' : 'none';
                });
            });
        });
    </script>
}
